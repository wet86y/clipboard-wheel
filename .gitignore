# --- Build output ---
# Generated by CMake/MSVC and release packaging. Reproducible per
# developer machine; never commit them.
build/
**/[Bb]in/
**/[Oo]bj/
artifacts/

# --- Debug symbols ---
*.pdb

# --- Visual Studio ---
.vs/
*.user
*.userosscache
*.suo
*.userprefs
*.sln.docstates

# --- Misc ---
# IDE-level caches that occasionally leak into the repo root
*.cache
*.AssemblyInfo*.cache

# --- Agent scratch ---
# One-off scripts written by the local agent to verify builds or inspect
# IL. Safe to delete. If you create new ones during a task, keep them
# here.
runtime_files/
.codex/
