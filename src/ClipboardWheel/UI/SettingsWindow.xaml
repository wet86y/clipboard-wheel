<Window x:Class="ClipboardWheel.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="超级中键设置"
        Width="760"
        Height="720"
        Icon="/Resources/app.ico"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="SwitchToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Canvas Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                                    <Border x:Name="Track"
                                            Width="{TemplateBinding Width}"
                                            Height="{TemplateBinding Height}"
                                    CornerRadius="11"
                                    Background="#B84A4A" />
                            <Ellipse x:Name="Thumb"
                                     Width="18"
                                     Height="18"
                                     Fill="White"
                                     Canvas.Left="2"
                                     Canvas.Top="2" />
                        </Canvas>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#2F8A4C" />
                                <Setter TargetName="Thumb" Property="Canvas.Left" Value="28" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Track" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="#4776C7" />
            <Setter Property="BorderBrush" Value="#244D91" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="8,0" />
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="8,6" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">
            <TabItem Header="基础设置">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <TextBlock Text="布局形状" Margin="0,0,0,4" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <RadioButton x:Name="ShapeCircleRadio" Content="圆形" GroupName="WheelShape" Margin="0,0,16,0" Checked="Shape_Changed" />
                            <RadioButton x:Name="ShapeRectangleRadio" Content="矩形" GroupName="WheelShape" Checked="Shape_Changed" />
                        </StackPanel>
                        <TextBlock x:Name="ShapeHintText" Text="圆形 4/6/8（切换默认 6），矩形 4/8（切换默认 8），矩形 8 区为九宫格掏空中心" Margin="0,0,0,12" TextWrapping="Wrap" Foreground="Gray" FontSize="11" />

                        <TextBlock Text="扇区数量（等级制）" />
                        <ComboBox x:Name="SectorCountBox" Width="160" HorizontalAlignment="Left" Margin="0,4,0,12" SelectionChanged="WheelPreviewSource_Changed" />

                        <TextBlock Text="轮盘大小" />
                        <Slider x:Name="RadiusSlider" Minimum="100" Maximum="300" TickFrequency="10" IsSnapToTickEnabled="True" />
                        <TextBlock x:Name="RadiusText" Margin="0,0,0,12" />

                        <TextBlock Text="中心死区半径" />
                        <Slider x:Name="DeadZoneSlider" Minimum="0" Maximum="120" TickFrequency="5" IsSnapToTickEnabled="True" />
                        <TextBlock x:Name="DeadZoneText" Margin="0,0,0,12" />

                        <TextBlock Text="透明度" />
                        <Slider x:Name="OpacitySlider" Minimum="0.2" Maximum="1.0" TickFrequency="0.05" IsSnapToTickEnabled="True" />
                        <TextBlock x:Name="OpacityText" Margin="0,0,0,12" />

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="快捷复制：最后一个扇区执行 Ctrl+C" VerticalAlignment="Center" Width="260" />
                            <ToggleButton x:Name="QuickCopyToggle" Style="{StaticResource SwitchToggleStyle}" Checked="Switch_Changed" Unchecked="Switch_Changed" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="捕获图片：复制图片后在轮盘中显示缩略图" VerticalAlignment="Center" Width="260" />
                            <ToggleButton x:Name="CaptureImagesToggle" Style="{StaticResource SwitchToggleStyle}" Checked="Switch_Changed" Unchecked="Switch_Changed" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <TextBlock Text="开机自启动：登录 Windows 后自动运行" VerticalAlignment="Center" Width="260" />
                            <ToggleButton x:Name="AutoStartToggle" Style="{StaticResource SwitchToggleStyle}" Checked="Switch_Changed" Unchecked="Switch_Changed" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                            <TextBlock Text="管理员模式运行" VerticalAlignment="Center" Width="260" />
                            <ToggleButton x:Name="AdministratorModeToggle"
                                          Style="{StaticResource SwitchToggleStyle}"
                                          Checked="AdministratorModeToggle_Changed"
                                          Unchecked="AdministratorModeToggle_Changed" />
                            <TextBlock x:Name="AdminRestartStatusText"
                                       Foreground="Gray"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="轮盘设置">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="突破轮盘" VerticalAlignment="Center" Width="84" />
                            <ToggleButton x:Name="ExtendedWheelToggle" Grid.Column="1" HorizontalAlignment="Left" Style="{StaticResource SwitchToggleStyle}" Checked="Switch_Changed" Unchecked="Switch_Changed" />
                            <TextBlock Grid.Column="2" Text="边界缓冲区" VerticalAlignment="Center" Margin="22,0,8,0" />
                            <StackPanel Grid.Column="3" Width="220">
                                <Slider x:Name="BreakoutBufferSlider" Minimum="0" Maximum="80" TickFrequency="2" IsSnapToTickEnabled="True" />
                                <TextBlock x:Name="BreakoutBufferText" HorizontalAlignment="Right" Foreground="Gray" FontSize="11" />
                            </StackPanel>
                        </Grid>

                        <Border Background="#F5F5F5" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="扩展动作槽位" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <Canvas x:Name="ExtendedWheelPreviewCanvas"
                                        Width="360"
                                        Height="360"
                                        HorizontalAlignment="Center"
                                        Background="Transparent"
                                        MouseLeftButtonDown="ExtendedWheelPreviewCanvas_MouseLeftButtonDown" />
                                <TextBlock x:Name="ExtendedPreviewHintText"
                                           Text="只可选择外圈扩展动作槽位；矩形模式下不触发突破轮盘。"
                                           HorizontalAlignment="Center"
                                           Foreground="Gray"
                                           FontSize="11"
                                           Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="8" Padding="12">
                            <StackPanel>
                                <TextBlock x:Name="SelectedSlotTitle" FontWeight="SemiBold" Margin="0,0,0,12" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="142" />
                                        <ColumnDefinition Width="14" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <ComboBox x:Name="SlotModeBox"
                                              Grid.Row="0"
                                              Grid.Column="0"
                                              SelectionChanged="SlotModeBox_SelectionChanged">
                                        <ComboBoxItem Content="快捷键" Tag="hotkey" />
                                        <ComboBoxItem Content="应用" Tag="shortcut" />
                                    </ComboBox>

                                    <TextBox x:Name="SlotNameBox"
                                             Grid.Row="0"
                                             Grid.Column="2"
                                             Height="34"
                                             FontSize="14"
                                             VerticalContentAlignment="Center"
                                             Padding="10,0"
                                             ToolTip="自定义名称，可为空"
                                             TextChanged="SlotEditor_Changed" />

                                    <Button x:Name="SlotActionButton"
                                            Grid.Row="2"
                                            Grid.Column="0"
                                            MinWidth="0"
                                            Padding="10,0"
                                            Style="{StaticResource PrimaryActionButtonStyle}"
                                            Click="SlotActionButton_Click" />

                                    <Border x:Name="SlotValuePanel"
                                            Grid.Row="2"
                                            Grid.Column="2"
                                            MinHeight="66"
                                            BorderBrush="#8EA9DA"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Background="#FAFCFF"
                                            Padding="10"
                                            AllowDrop="True"
                                            DragOver="ShortcutDrop_DragOver"
                                            Drop="ShortcutDrop_Drop"
                                            MouseLeftButtonUp="ShortcutDropPanel_MouseLeftButtonUp">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Image x:Name="ShortcutIconImage"
                                                   Width="36"
                                                   Height="36"
                                                   Margin="0,0,10,0"
                                                   VerticalAlignment="Center"
                                                   Visibility="Collapsed" />
                                            <TextBlock x:Name="SlotValueText"
                                                       Grid.Column="1"
                                                       VerticalAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       Foreground="#333333" />
                                        </Grid>
                                    </Border>
                                </Grid>

                                <StackPanel x:Name="ShortcutBehaviorPanel" Orientation="Horizontal" Margin="0,12,0,0">
                                    <TextBlock Text="应用第二次触发" VerticalAlignment="Center" Width="120" />
                                    <ComboBox x:Name="SlotSecondBehaviorBox" Width="160">
                                        <ComboBoxItem Content="最小化" Tag="minimize" />
                                        <ComboBoxItem Content="直接关闭" Tag="close" />
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel x:Name="BrowserLaunchUrlPanel" Margin="0,10,0,0" Visibility="Collapsed">
                                    <TextBlock Text="浏览器启动网址（可选）" FontWeight="SemiBold" />
                                    <TextBox x:Name="BrowserLaunchUrlBox"
                                             Height="32"
                                             Margin="0,6,0,0"
                                             VerticalContentAlignment="Center"
                                             Padding="10,0"
                                             ToolTip="留空时按快捷方式启动；填写 https://... 时沿用浏览器原有 Profile 打开该网址"
                                             TextChanged="SlotEditor_Changed" />
                                    <TextBlock Text="沿用现有浏览器 Profile：登录态、Cookie、扩展和设置保持可用。"
                                               Foreground="Gray"
                                               FontSize="11"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="关于">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <WrapPanel Margin="0,0,0,12">
                            <Button x:Name="AboutCheckUpdateButton"
                                    Content="检查更新"
                                    Width="120"
                                    Height="38"
                                    Margin="0,0,8,0"
                                    Click="CheckUpdate_Click" />
                            <Button x:Name="AboutInstallUpdateButton"
                                    Content="下载并安装"
                                    Height="38"
                                    Padding="14,0"
                                    Margin="0,0,8,0"
                                    Visibility="Collapsed"
                                    Click="InstallUpdate_Click" />
                            <Button x:Name="AboutPauseResumeButton"
                                    Content="暂停下载"
                                    Height="38"
                                    Padding="12,0"
                                    Margin="0,0,8,0"
                                    Visibility="Collapsed"
                                    Click="PauseResumeDownload_Click" />
                            <Button x:Name="AboutBackgroundDownloadButton"
                                    Content="转入后台下载"
                                    Height="38"
                                    Padding="12,0"
                                    Margin="0,0,8,0"
                                    Visibility="Collapsed"
                                    Click="BackgroundDownload_Click" />
                            <Button x:Name="AboutCancelDownloadButton"
                                    Content="取消下载"
                                    Height="38"
                                    Padding="12,0"
                                    Visibility="Collapsed"
                                    Click="CancelDownload_Click" />
                        </WrapPanel>
                        <WrapPanel Margin="0,0,0,12">
                            <StackPanel x:Name="AboutAccelerationOptionPanel"
                                        Orientation="Horizontal"
                                        Visibility="Collapsed">
                                <TextBlock Text="使用加速节点"
                                           VerticalAlignment="Center"
                                           Width="260" />
                                <ToggleButton x:Name="AboutAccelerationToggle"
                                              Style="{StaticResource SwitchToggleStyle}"
                                              Checked="AccelerationToggle_Changed"
                                              Unchecked="AccelerationToggle_Changed" />
                            </StackPanel>
                            <Button x:Name="AboutSwitchNodeButton"
                                    Content="切换加速节点"
                                    Height="30"
                                    Padding="10,0"
                                    Visibility="Collapsed"
                                    Click="SwitchUpdateNode_Click" />
                        </WrapPanel>
                        <TextBlock x:Name="AboutUpdateStatusText"
                                   Foreground="Gray"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8" />
                        <ProgressBar x:Name="UpdateProgressBar"
                                     Minimum="0"
                                     Maximum="1"
                                     Height="18"
                                     Visibility="Collapsed"
                                     Margin="0,0,0,18" />
                        <Border x:Name="AboutReleaseNotesBorder"
                                Visibility="Collapsed"
                                Background="#12000000"
                                CornerRadius="6"
                                Padding="12"
                                Margin="0,0,0,18">
                            <StackPanel>
                                <TextBlock Text="更新说明" FontWeight="SemiBold" Margin="0,0,0,6" />
                                <TextBlock x:Name="AboutReleaseNotesText"
                                           Foreground="Gray"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <TextBlock Text="超级中键"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12" />
                        <TextBlock Text="轻量级 Windows 剪贴板轮盘与效率工具。"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,18" />
                        <TextBlock Text="开发者：wet86y" Margin="0,0,0,8" />
                        <TextBlock Margin="0,0,0,8">
                            <Run Text="GitHub 历史：" />
                            <Hyperlink NavigateUri="https://github.com/wet86y/clipboard-wheel"
                                       RequestNavigate="GitHubHistory_Click">
                                查看项目仓库与更新记录
                            </Hyperlink>
                        </TextBlock>
                        <TextBlock Text="当前版本：" Margin="0,0,0,4" />
                        <TextBlock x:Name="AboutVersionText" Foreground="Gray" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" Content="保存" Width="88" Margin="0,0,8,0" Click="Save_Click" />
            <Button Grid.Column="2" Content="关闭" Width="88" Click="Close_Click" />
        </Grid>
    </Grid>
</Window>
